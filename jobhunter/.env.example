# Database
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# API Keys (required — real API keys needed)
OPENAI_API_KEY=sk-...
HUNTER_API_KEY=...
RESEND_API_KEY=re_...

# Resend webhook verification
RESEND_WEBHOOK_SECRET=whsec_...

# Unsubscribe link signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
UNSUBSCRIBE_SECRET=

# Email sending
DAILY_EMAIL_LIMIT=50
SENDER_EMAIL=outreach@eran-jobs.com
SENDER_NAME=Eran
PHYSICAL_ADDRESS=Tel Aviv, Israel

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Paths (optional — defaults are relative to backend/ dir)
# UPLOAD_DIR=C:\Users\Eran\Desktop\Personal\JobSearch\jobhunter\backend\data\uploads
