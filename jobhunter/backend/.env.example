# ===================================================================
# JobHunter Backend — Environment Variables
# Copy this file to .env and fill in real values.
# ===================================================================

# Database (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — REQUIRED: generate a strong random secret before running
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# API Keys — required for full functionality
OPENAI_API_KEY=sk-...
HUNTER_API_KEY=...
RESEND_API_KEY=re_...

# Resend webhook verification secret (from Resend dashboard)
RESEND_WEBHOOK_SECRET=whsec_...

# Unsubscribe link signing
# python -c "import secrets; print(secrets.token_urlsafe(32))"
UNSUBSCRIBE_SECRET=

# Email sending
DAILY_EMAIL_LIMIT=50
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=YourName
PHYSICAL_ADDRESS=Your City, Country

# API cost limits (daily per user)
DAILY_OPENAI_CALL_LIMIT=100
DAILY_HUNTER_CALL_LIMIT=50
DAILY_DISCOVERY_LIMIT=10
DAILY_RESEARCH_LIMIT=5

# Invites
INVITE_EXPIRE_DAYS=7

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Sentry error monitoring (optional — leave empty to disable)
# Get DSN from https://sentry.io → Create project (FastAPI) → Copy DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database pool settings (optional — sensible defaults)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# Cloudflare R2 storage (optional — falls back to local filesystem)
# R2_ENDPOINT_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# pgBouncer (optional - set to use connection pooling proxy)
# PGBOUNCER_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:6432/jobhunter
