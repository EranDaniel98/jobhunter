# ===================================================================
# JobHunter Backend — Environment Variables
# Copy this file to .env and fill in real values.
# ===================================================================

# Database (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:5432/jobhunter

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — REQUIRED: generate a strong random secret before running
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ACCESS_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=30

# API Keys — required for full functionality
OPENAI_API_KEY=sk-...
HUNTER_API_KEY=...
RESEND_API_KEY=re_...

# Resend webhook verification secret (from Resend dashboard)
RESEND_WEBHOOK_SECRET=whsec_...

# Unsubscribe link signing
# python -c "import secrets; print(secrets.token_urlsafe(32))"
UNSUBSCRIBE_SECRET=

# Email sending
DAILY_EMAIL_LIMIT=50
SENDER_EMAIL=outreach@yourdomain.com
SENDER_NAME=YourName
PHYSICAL_ADDRESS=Your City, Country

# API cost limits (daily per user)
DAILY_OPENAI_CALL_LIMIT=100
DAILY_HUNTER_CALL_LIMIT=50
DAILY_DISCOVERY_LIMIT=10
DAILY_RESEARCH_LIMIT=5

# Invites
INVITE_EXPIRE_DAYS=7

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Sentry error monitoring (optional — leave empty to disable)
# Get DSN from https://sentry.io → Create project (FastAPI) → Copy DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database pool settings (optional — sensible defaults)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# Cloudflare R2 storage (optional — falls back to local filesystem)
# R2_ENDPOINT_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# pgBouncer (optional - set to use connection pooling proxy)
# PGBOUNCER_URL=postgresql+asyncpg://jobhunter:jobhunter@localhost:6432/jobhunter

# Waitlist invites
# MAX_DAILY_INVITES=200

# DNS Health
# DKIM_SELECTOR=resend
# SPF_EXPECTED_INCLUDES=["amazonses.com","resend.com"]
# DNS_HEALTH_CACHE_TTL=300
# DNS_LOOKUP_TIMEOUT=3.0

# Dossier caching
# DOSSIER_CACHE_TTL=604800

# ARQ Batching
# ARQ_CHUNK_SIZE=10
# ARQ_CHUNK_CONCURRENCY=5
# ARQ_MAX_CHUNKS_PER_RUN=50

# LLM model overrides (default: gpt-4o-mini for low-stakes calls)
SCOUT_QUERIES_MODEL=gpt-4o-mini
SCOUT_PARSE_MODEL=gpt-4o-mini
ANALYTICS_INSIGHTS_MODEL=gpt-4o-mini

# Scout fit-score threshold (0.0-1.0). Cross-domain cosine similarity
# between resume-DNA and company-description embeddings runs low;
# validated range in prod is 0.09-0.32.
SCOUT_FIT_THRESHOLD=0.25

# GitHub (incident sync to GitHub Issues)
GITHUB_TOKEN=ghp_your_fine_grained_pat_here
GITHUB_REPO=EranDaniel98/jobhunter
